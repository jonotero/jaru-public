import "Globals"
import "Ray"
import "Vector"
import "Camera"
import "Material"

class Object
    def init()
        this.bboxMin=Vector();
        this.bboxMax=Vector();
        this.pos=Vector()
        this.mat=[Material(),Material()];
    end;
end;
