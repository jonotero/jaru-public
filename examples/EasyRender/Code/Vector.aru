import "Globals"

// =========================================================
// Contruccion de un vector a partir de sus coordenadas
// =========================================================
class Vector
    // ---------------------------------------
    // Constructor de un vector por defecto.
    // ---------------------------------------
    def init();
        this.x=0.0;
        this.y=0.0;
        this.z=0.0;
    end

    // -------------------------------------------------------------
    // Constructor de un vector a partir de otro vector.
    // -------------------------------------------------------------
    def init(v1)
        this.x=v1.x;
        this.y=v1.y;
        this.z=v1.z;
    end;

    // -------------------------------------------------------------
    // Constructor de un vector a partir de las coordenadas dadas.
    // -------------------------------------------------------------
    def init(x,y,z);
        this.x=x
        this.y=y;
        this.z=z;
    end

    // -------------------------------------------------------------
    // Sobrecarga del operador suma, para soportar vector+vector
    // vector+escalar
    // -------------------------------------------------------------
    operator + (v1,v2)
        var result=Vector(0,0,0);
        if (type(v2)==tInteger or type(v2)==tFloat ) then
            result.x=v1.x+v2;
            result.y=v1.y+v2;
            result.z=v1.z+v2;
        else
            result.x=v1.x+v2.x;
            result.y=v1.y+v2.y;
            result.z=v1.z+v2.z;
        end;
        return(result);
    end;

    // -------------------------------------------------------------
    // Negar un vector.
    // -------------------------------------------------------------
    operator - (v1)
        var result=Vector(0,0,0);
        result.x=-v1.x;
        result.y=-v1.y;
        result.z=-v1.z;
        return(result);
    end;

    // -------------------------------------------------------------
    // Resta de vector menos vector y vector menos escalar
    // -------------------------------------------------------------
    operator - (v1,v2)
        var result=Vector(0,0,0);
        if (type(v2)==tInteger or type(v2)==tFloat ) then
            result.x=v1.x-v2;
            result.y=v1.y-v2;
            result.z=v1.z-v2;
        else
            result.x=v1.x-v2.x;
            result.y=v1.y-v2.y;
            result.z=v1.z-v2.z;
        end;
        return(result);
    end;

    // -------------------------------------------------------------
    // Multiplicacion de un vector por un vector y de un vector por
    // un escalar
    // -------------------------------------------------------------
    operator * (v1,v2)
        var result=Vector(0,0,0);
        if (type(v2)==tInteger or type(v2)==tFloat ) then
            result.x=v1.x*v2;
            result.y=v1.y*v2;
            result.z=v1.z*v2;
        else
            result.x=v1.x*v2.x;
            result.y=v1.y*v2.y;
            result.z=v1.z*v2.z;
        end;
        return(result)
    end;

    // -------------------------------------------------------------
    // Division de un vector por un escalar
    // -------------------------------------------------------------
    operator / (v1,n)
        var result=Vector(0,0,0);
        result.x=v1.x/n;
        result.y=v1.y/n;
        result.z=v1.z/n;
        return(result);
    end;

    // -------------------------------------------------------------
    // Producto Escalar
    // -------------------------------------------------------------
    operator | (v1,v2)
        return(v1.x*v2.x + v1.y*v2.y + v1.z*v2.z);
    end;

    // -------------------------------------------------------------
    // Producto Vectorial
    // -------------------------------------------------------------
    operator & (v1,v2)
        var result=Vector(0,0,0);
        result.x=v1.y*v2.z - v1.z*v2.y;
        result.y=v1.z*v2.x - v1.x*v2.z;
        result.z=v1.x*v2.y - v1.y*v2.x;
        return(result);
    end;

    // -----------------------------------------------------------------
    // Normalizar vector
    // -----------------------------------------------------------------
    operator ! (v1)
        var result=v1.copy();
        var modulo=0.0;

        // El modulo de un vector es la raiz cuadrada de su producto escalar
        modulo = sqrt(v1 | v1)
        if (modulo>1+EPSILON or (modulo<1-EPSILON and modulo>EPSILON))then
            result.x=v1.x/modulo;
            result.y=v1.y/modulo;
            result.z=v1.z/modulo;
        end;
        return(result);
    end;

    // ----------------------------------------------------
    // Comprueba si algun componente del vector es mayor
    // que un escalar
    // ----------------------------------------------------
    operator > (v1,n)
        return (v1.x>n or v1.y>n or v1.z>n)
    end;

    // ------------------------------------------------------------------
    // Fuerza que ningun componente del vector sea mayor que el indicado
    // ------------------------------------------------------------------
    def ComoMucho(n)
        if (this.x > n) then
            this.x=n
        end;
        if (this.y > n) then
            this.y=n
        end;
        if (this.z > n) then
            this.z=n
        end;
    end;


    // ------------------------------------------------------------------
    // Fuerza que ningun componente del vector sea menor que el indicado
    // ------------------------------------------------------------------
    def ComoPoco(n)
        if (this.x < n) then
            this.x=n
        end;
        if (this.y < n) then
            this.y=n
        end;
        if (this.z < n) then
            this.z=n
        end;
    end;

    // -------------------------------------------------------------------------
    // Devuelve la componente de mayor valor absoluto (coordenada dominante).
    // -------------------------------------------------------------------------
    def Dominante()
        var auxX=abs(this.x), auxY=abs(this.y), auxZ=abs(this.z);
        var dominante;
        if ((auxX> auxY) and (auxX>auxZ)) then
            dominante=0;
        elsif (auxY>auxZ) then
            dominante=1;
        else
            dominante=2;
        end
        return(dominante);
    end

    // ---------------------------------------------------------------------
    // Comprueba si hay algun componente del vector positivo.
    // ---------------------------------------------------------------------
    def AlgunoPositivo()
        return ((this.x>EPSILON) or (this.y>EPSILON) or (this.z>EPSILON))
    end;

end


