use Display, Sprite, Input, Timer, GridMap

var draw = Display.draw;

import "Pacman_Map.aru"

// ============================================================
// Main game GridMap - replaces the two-dimensional array
// ============================================================
var gridMap = GridMap.new(MAP_COLUMNAS, MAP_FILAS)

// ============================================================
// Global variables for distance maps
// ============================================================
var distMapPacman = nil // Distance map toward Pacman
var distMapHome = nil // Distance map toward the ghost house (for eyes)
var scatterMaps = [] // Scatter maps for each ghost
var lastPacmanCellX = -1
var lastPacmanCellY = -1

// Passable cells for ghosts (includes house=4)
const GHOST_PASSABLE = [1, 2, 3, 4, 5]

// Temporary values used to mark target cells in the GridMap
const TEMP_MARKER_PACMAN = 99
const TEMP_MARKER_HOME = 98
const TEMP_MARKER_SCATTER = 97

// ============================================================
// Dumps the initial array map into the GridMap
// ============================================================
func MapToGrid()
    for (var row = 0;row < MAP_FILAS;row++)
        for (var col = 0;col < MAP_COLUMNAS;col++)
            gridMap.set(col, row, mapa[row][col])
        end
    end
    totalDots = gridMap.count(2) + gridMap.count(3)
    println("Total dots: ", totalDots)
end

enum DIRECTION
    UP, DOWN, LEFT, RIGHT
end;

enum GHOST
    blinky, pinky, inky, clyde
end

enum STATE
    chase, scatter, frighten, dead, housed
end

enum GAME_STATE
    start, playing, lifelost, levelcomplete, gameover
end

var StatusGame = GAME_STATE.start

const FPS = 25

// 224x288
const WIDTH = 320
const HEIGHT = 240
const VIEW_W = 224
const VIEW_H = 288

const TUNNEL_ROW = 14
const PACMAN_START_CELL_X = 14;
const PACMAN_START_CELL_Y = 23;

var PlayerScore = 0;
var PlayerLives = 3;
var currentLevel = 1;
var BonusActive = 0
var dotsEatenCounter = 0;
var dotsEatenThisLife = 0;
var hudNeedsClearing = true

var ghostReleaseTimer = 0;

var SPEED_PACMAN
var SPEED_GHOST
var FRAMEPAUSE

// =================================================================
// FRUIT SYSTEM - GLOBAL VARIABLES
// =================================================================

var fruitActive = false
var fruitAppearCount = 0
var fruitTimerId = -1

const FRUIT_DURATION_MS = 9000
const FRUIT_APPEAR_DOTS_1 = 70
const FRUIT_APPEAR_DOTS_2 = 170
const FRUIT_CELL_X = 13
const FRUIT_CELL_Y = 17

// =================================================================
// Ghost Mode Variables
// =================================================================

