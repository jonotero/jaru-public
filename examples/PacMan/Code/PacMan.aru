    {"level" : 11, "fruitIndex" : 6, "points" : 3000},
    {"level" : 13, "fruitIndex" : 7, "points" : 5000}
]

var currentModeIndex = 0;
var modeTimer = 0;
var GLOBAL_GHOST_STATE = levelModePattern[0][0];

const FRIGHT_DURATION = 6 * FPS;
const FRIGHT_BLINK_WINDOW_MS = 2000
var frightBlinkTimerId = -1
var isFrightBlinkActive = false

var frightTimerId = -1;

