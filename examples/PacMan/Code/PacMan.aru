    {"level" : 1, "fruitIndex" : 0, "points" : 100},
    {"level" : 2, "fruitIndex" : 1, "points" : 300},
    {"level" : 3, "fruitIndex" : 2, "points" : 500},
    {"level" : 5, "fruitIndex" : 3, "points" : 700},
